generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile                Profile?
  accountVerificationCodes AccountVerificationCode[]
  cycleLogs              CycleLog[]
  symptomEntries         SymptomEntry[]
  moodEntries            MoodEntry[]
  flowEntries            FlowEntry[]
  notes                  Note[]
  temperatureEntries     TemperatureEntry[]
  weightEntries          WeightEntry[]
  waterEntries           WaterEntry[]
  activityEntries        ActivityEntry[]
  sleepEntries           SleepEntry[]
  intercourseEntries     IntercourseEntry[]
  medicationEntries      MedicationEntry[]
  notificationSettings   NotificationSettings?
  notificationDevices    NotificationDevice[]
  notificationDeliveries NotificationDelivery[]
  safetyProfile          SafetyProfile?
  emergencyContacts      EmergencyContact[]
  safetyLocations        SafetyLocation[]
  alertSessions          AlertSession[]
  alertEvents            AlertEvent[]
  alertLocationSamples   AlertLocationSample[]
  evidenceRecords        EvidenceRecord[]
  evidenceAuditEvents    EvidenceAuditEvent[]
  evidenceAnalyses       EvidenceAnalysis[]
}

model Profile {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String?
  phone             String?
  phoneVerifiedAt   DateTime?
  birthDate         DateTime?
  cpf               String?   @unique
  avgCycleLength    Int?
  avgPeriodDuration Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum AccountVerificationChannel {
  EMAIL
  PHONE
}

model AccountVerificationCode {
  id           String                     @id @default(uuid())
  userId       String
  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel      AccountVerificationChannel
  destination  String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int                        @default(0)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@index([userId, channel, createdAt])
  @@index([userId, channel, expiresAt])
  @@index([destination, channel, createdAt])
}

// ─── CYCLE ───────────────────────────────────────────────────────────────────

model CycleLog {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate DateTime
  endDate   DateTime?
  duration  Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── SYMPTOMS ────────────────────────────────────────────────────────────────

model Symptom {
  id      String         @id @default(uuid())
  name    String         @unique
  entries SymptomEntry[]
}

model SymptomEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptomId String
  symptom   Symptom  @relation(fields: [symptomId], references: [id])
  date      DateTime
  intensity Int?
  createdAt DateTime @default(now())
}

// ─── MOOD ────────────────────────────────────────────────────────────────────

enum MoodType {
  HAPPY
  SAD
  ANXIOUS
  IRRITABLE
  CALM
  ENERGETIC
  TIRED
  SENSITIVE
}

model MoodEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood      MoodType
  date      DateTime
  note      String?
  createdAt DateTime @default(now())
}

// ─── FLOW ────────────────────────────────────────────────────────────────────

enum FlowIntensity {
  SPOTTING
  LIGHT
  MEDIUM
  HEAVY
  VERY_HEAVY
}

model FlowEntry {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  intensity FlowIntensity
  date      DateTime
  createdAt DateTime      @default(now())
}

// ─── NOTES ───────────────────────────────────────────────────────────────────

model Note {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── HEALTH TRACKING ─────────────────────────────────────────────────────────

model TemperatureEntry {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  temperature Float
  date        DateTime
  createdAt   DateTime @default(now())
}

model WeightEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weight    Float
  date      DateTime
  createdAt DateTime @default(now())
}

model WaterEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  date      DateTime
  createdAt DateTime @default(now())
}

enum ActivityType {
  WALKING
  RUNNING
  CYCLING
  SWIMMING
  YOGA
  GYM
  DANCING
  OTHER
}

enum ActivityIntensity {
  LOW
  MEDIUM
  HIGH
}

model ActivityEntry {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActivityType
  intensity ActivityIntensity
  duration  Int
  date      DateTime
  createdAt DateTime          @default(now())
}

enum SleepQuality {
  POOR
  FAIR
  GOOD
  EXCELLENT
}

model SleepEntry {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  hours     Float
  quality   SleepQuality
  date      DateTime
  createdAt DateTime     @default(now())
}

model IntercourseEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  protected Boolean
  date      DateTime
  createdAt DateTime @default(now())
}

model MedicationEntry {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  dose      String?
  date      DateTime
  createdAt DateTime @default(now())
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model NotificationSettings {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodReminder     Boolean  @default(true)
  ovulationReminder  Boolean  @default(true)
  medicationReminder Boolean  @default(false)
  waterReminder      Boolean  @default(false)
  reminderHour       Int      @default(8)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model NotificationDevice {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  platform   String?
  enabled    Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model NotificationDelivery {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  referenceDate DateTime
  title         String
  body          String
  sentAt        DateTime @default(now())

  @@unique([userId, type, referenceDate])
  @@index([userId, referenceDate])
}

// ─── VERA SAFETY LAYER ──────────────────────────────────────────────────────

enum SafetyLocationType {
  TRUSTED
  RISK
}

enum AlertTrigger {
  MANUAL
  LOCATION
}

enum AlertStatus {
  ACTIVE
  RESOLVED
  CANCELLED
}

enum AlertLevel {
  NORMAL
  CRITICAL
}

enum AlertEventType {
  SESSION_STARTED
  LOCATION_ENTERED
  LOCATION_UPDATED
  EVIDENCE_UPLOADED
  AI_ANALYSIS_COMPLETED
  ALERT_ESCALATED
  CONTACT_NOTIFIED
  CONTACT_NOTIFICATION_FAILED
  SESSION_CLOSED
}

enum EvidenceType {
  AUDIO
  VIDEO
  IMAGE
  FILE
}

enum EvidenceAuditAction {
  UPLOADED
  HASH_VERIFIED
  CHUNK_CHAIN_VERIFIED
  HIDDEN_FROM_USER
}

enum EvidenceChunkChainStatus {
  NOT_APPLICABLE
  ROOT
  VERIFIED
  PENDING_PREVIOUS
}

enum LocationSampleSource {
  FOREGROUND
  BACKGROUND
  UNKNOWN
}

enum EvidenceAnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  INCONCLUSIVE
}

model SafetyProfile {
  id                           String    @id @default(uuid())
  userId                       String    @unique
  user                         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  veraEnabled                  Boolean   @default(false)
  consentAccepted              Boolean   @default(false)
  consentAcceptedAt            DateTime?
  pinHash                      String?
  pinUpdatedAt                 DateTime?
  biometricUnlockEnabled       Boolean   @default(false)
  discreetNotificationsEnabled Boolean   @default(true)
  monitoringEnabled            Boolean   @default(false)
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
}

model EmergencyContact {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  relationship String?
  priority     Int      @default(0)
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, enabled])
  @@index([userId, priority])
}

model SafetyLocation {
  id            String             @id @default(uuid())
  userId        String
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  latitude      Float
  longitude     Float
  radiusMeters  Int
  type          SafetyLocationType @default(RISK)
  enabled       Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  alertSessions AlertSession[]

  @@index([userId, enabled])
  @@index([userId, type])
}

model AlertSession {
  id                  String                @id @default(uuid())
  userId              String
  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  safetyLocationId    String?
  safetyLocation      SafetyLocation?       @relation(fields: [safetyLocationId], references: [id], onDelete: SetNull)
  trigger             AlertTrigger
  status              AlertStatus           @default(ACTIVE)
  level               AlertLevel            @default(NORMAL)
  startedAt           DateTime              @default(now())
  endedAt             DateTime?
  criticalEscalatedAt DateTime?
  initialLatitude     Float?
  initialLongitude    Float?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  events              AlertEvent[]
  locationSamples     AlertLocationSample[]
  evidenceRecords     EvidenceRecord[]
  evidenceAnalyses    EvidenceAnalysis[]

  @@index([userId, status])
  @@index([userId, level])
  @@index([userId, startedAt])
  @@index([safetyLocationId])
}

model AlertEvent {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertSessionId String
  alertSession   AlertSession   @relation(fields: [alertSessionId], references: [id], onDelete: Cascade)
  type           AlertEventType
  message        String?
  metadata       Json?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime       @default(now())

  @@index([alertSessionId, createdAt])
  @@index([userId, createdAt])
  @@index([type])
}

model AlertLocationSample {
  id                   String               @id @default(uuid())
  userId               String
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertSessionId       String
  alertSession         AlertSession         @relation(fields: [alertSessionId], references: [id], onDelete: Cascade)
  evidenceRecordId     String?
  evidenceRecord       EvidenceRecord?      @relation(fields: [evidenceRecordId], references: [id], onDelete: SetNull)
  latitude             Float
  longitude            Float
  accuracyMeters       Float?
  altitudeMeters       Float?
  speedMetersPerSecond Float?
  headingDegrees       Float?
  source               LocationSampleSource @default(UNKNOWN)
  capturedAt           DateTime
  metadata             Json?
  createdAt            DateTime             @default(now())

  @@index([userId, capturedAt])
  @@index([alertSessionId, capturedAt])
  @@index([evidenceRecordId])
  @@index([source])
}

model EvidenceRecord {
  id                String                   @id @default(uuid())
  userId            String
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertSessionId    String
  alertSession      AlertSession             @relation(fields: [alertSessionId], references: [id], onDelete: Cascade)
  type              EvidenceType
  size              Int
  mimeType          String
  originalName      String?
  storagePath       String                   @unique
  contentHash       String
  hashAlgorithm     String                   @default("SHA-256")
  hashedAt          DateTime                 @default(now())
  clientUploadId    String?
  chunkSequenceId   String?
  chunkIndex        Int?
  previousChunkHash String?
  chunkChainStatus  EvidenceChunkChainStatus @default(NOT_APPLICABLE)
  hiddenFromUserAt  DateTime?
  retentionUntil    DateTime?
  deletedAt         DateTime?
  metadata          Json?
  createdAt         DateTime                 @default(now())
  auditEvents       EvidenceAuditEvent[]
  analyses          EvidenceAnalysis[]
  locationSamples   AlertLocationSample[]

  @@unique([userId, clientUploadId])
  @@unique([alertSessionId, chunkSequenceId, chunkIndex])
  @@index([userId, createdAt])
  @@index([userId, hiddenFromUserAt])
  @@index([alertSessionId, createdAt])
  @@index([alertSessionId, chunkSequenceId, chunkIndex])
  @@index([contentHash])
  @@index([chunkChainStatus])
  @@index([retentionUntil])
  @@index([deletedAt])
  @@index([type])
}

model EvidenceAuditEvent {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  evidenceRecordId  String
  evidenceRecord    EvidenceRecord      @relation(fields: [evidenceRecordId], references: [id], onDelete: Cascade)
  action            EvidenceAuditAction
  contentHash       String?
  hashAlgorithm     String              @default("SHA-256")
  previousEventHash String?
  eventHash         String              @unique
  metadata          Json?
  createdAt         DateTime            @default(now())

  @@index([userId, createdAt])
  @@index([evidenceRecordId, createdAt])
  @@index([action])
}

model EvidenceAnalysis {
  id                   String                 @id @default(uuid())
  analysisId           String?
  analysisVersion      String?
  userId               String
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertSessionId       String
  alertSession         AlertSession           @relation(fields: [alertSessionId], references: [id], onDelete: Cascade)
  evidenceRecordId     String
  evidenceRecord       EvidenceRecord         @relation(fields: [evidenceRecordId], references: [id], onDelete: Cascade)
  requestKey           String?                @unique
  status               EvidenceAnalysisStatus
  attemptCount         Int                    @default(0)
  maxAttempts          Int                    @default(3)
  nextAttemptAt        DateTime?              @default(now())
  lockedAt             DateTime?
  lastAttemptAt        DateTime?
  riskLevel            String?
  suggestedAlertLevel  AlertLevel?
  confidence           Float?
  summary              String?
  detectedSignals      Json?
  shouldEscalate       Boolean?
  recommendedAction    String?
  evidenceWindow       Json?
  transcription        Json?
  acousticEvents       Json?
  threatMatches        Json?
  providerMetadata     Json?
  processingStartedAt  DateTime?
  processingFinishedAt DateTime?
  latencyMs            Int?
  failureReason        String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([userId, createdAt])
  @@index([alertSessionId, createdAt])
  @@index([evidenceRecordId, createdAt])
  @@index([status])
  @@index([status, nextAttemptAt])
  @@index([status, lockedAt])
  @@index([suggestedAlertLevel])
}
