# Database
DATABASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=vera-evidence
EMERGENCY_DISPATCH_CHANNELS=sms
EMERGENCY_SMS_PROVIDER=mock
EMERGENCY_WHATSAPP_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE_NUMBER=
TWILIO_WHATSAPP_FROM_PHONE_NUMBER=

# AI service
AI_SERVICE_URL=
AI_SERVICE_TIMEOUT_MS=5000
VERA_AI_ANALYSIS_WORKER_ENABLED=true
VERA_AI_ANALYSIS_WORKER_POLL_MS=1000
VERA_AI_ANALYSIS_WORKER_BATCH_SIZE=4
VERA_AI_ANALYSIS_MAX_ATTEMPTS=3
VERA_AI_ANALYSIS_RETRY_BASE_MS=1000
VERA_AI_ANALYSIS_RETRY_MAX_MS=30000
VERA_AI_ANALYSIS_LOCK_TIMEOUT_MS=60000
VERA_AI_CRITICAL_CONFIDENCE_THRESHOLD=0.78
VERA_AI_CRITICAL_THREAT_CONFIDENCE_THRESHOLD=0.7
VERA_AI_CRITICAL_ACOUSTIC_CONFIDENCE_THRESHOLD=0.72
VERA_AI_CRITICAL_MIN_SIGNAL_REASONS=2
VERA_AI_CRITICAL_RECURRENCE_WINDOW_MS=300000
VERA_AI_CRITICAL_RECURRENCE_MIN_PREVIOUS=1

# Auth
JWT_SECRET=

# App
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Browser clients need CORS. Leave empty in local development to allow any
# origin; set a comma-separated allowlist in shared/prod environments.
CORS_ORIGINS=
